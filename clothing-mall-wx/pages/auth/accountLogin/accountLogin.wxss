.container {
  height: 100vh;
  box-sizing: border-box;
  background-color: #fff;
  position: relative;
}

/* 重置微信原生 button 默认样式 */
button {
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
}
button::after {
  display: none;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  z-index: 999;
  background: transparent;
}

.nav-inner {
  height: 48px;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.nav-left {
  width: 56px;
  height: 48px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-left-hover {
  opacity: 0.6;
}

.arrow {
  width: 12px;
  height: 12px;
  border-left: 2px solid #333;
  border-bottom: 2px solid #333;
  transform: rotate(45deg);
}

.header-bg {
  width: 100%;
  height: 60vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.bg-img {
  width: 100%;
  height: 100%;
}

.login-card {
  position: absolute;
  top: 45vh;
  left: 0;
  width: 100%;
  min-height: 55vh;
  background-color: #fff;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  z-index: 2;
  padding: 60rpx 60rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 60rpx;
}

.form-item {
  position: relative;
  background: #F5F5F5;
  height: 96rpx;
  border-radius: 48rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}

.input-icon {
  font-size: 36rpx;
  color: #666;
  margin-right: 20rpx;
}

.form-item .username, .form-item .password {
  flex: 1;
  height: 96rpx;
  color: #333;
  font-size: 28rpx;
  background: transparent;
}

.form-item .clear {
  padding: 20rpx;
  color: #999;
  font-size: 32rpx;
}

.send-code-btn {
  font-size: 24rpx;
  color: #FF8096;
  padding: 10rpx 0 10rpx 20rpx;
  z-index: 2;
}

.form-item-text {
  display: flex;
  justify-content: flex-end;
  width: 100%;
  margin-top: -10rpx;
  margin-bottom: 60rpx;
}

.form-item-text .reset {
  font-size: 24rpx;
  color: #999;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  color: #fff;
  border-radius: 48rpx;
  background: #FF8096;
  margin-bottom: 40rpx;
  font-weight: 500;
}

.register-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 26rpx;
  margin-bottom: auto; /* pushes agreement to bottom */
}

.no-account {
  color: #333;
}

.register-wrap .register {
  color: #FF8096;
}

.agreement-wrap {
  margin-top: 80rpx;
}

.checkbox-label {
  display: flex;
  align-items: flex-start;
}

.custom-checkbox {
  transform: scale(0.6);
  margin-right: 4rpx;
  margin-top: -6rpx;
}

.agreement-text {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
  flex: 1;
}

.agreement-text .link {
  color: #5D9CEC;
  display: inline;
}
