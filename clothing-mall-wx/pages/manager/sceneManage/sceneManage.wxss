@import "../../../styles/manager-common.wxss";

.container {
  min-height: 100vh;
  background-color: #F7F8FA;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ---- 导航栏 ---- */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  position: relative;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.nav-action {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-add-icon {
  width: 24rpx;
  height: 24rpx;
  position: relative;
}

.nav-add-icon::before,
.nav-add-icon::after {
  content: '';
  position: absolute;
  background: #FF8096;
  border-radius: 2rpx;
}

.nav-add-icon::before {
  width: 100%;
  height: 4rpx;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
}

.nav-add-icon::after {
  width: 4rpx;
  height: 100%;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
}

.nav-placeholder {
  background: transparent;
}

/* ---- 场景卡片列表 ---- */
.scene-list {
  padding: 20rpx 24rpx;
}

.scene-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s ease;
}

.scene-card:active {
  transform: scale(0.98);
}

/* ---- 海报缩略图 ---- */
.scene-poster {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.poster-img {
  width: 100%;
  height: 100%;
}

.scene-poster--empty {
  background: linear-gradient(135deg, #F0EBE6, #F7F3EF);
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster-placeholder {
  width: 36rpx;
  height: 36rpx;
  border-radius: 4rpx;
  border: 2rpx dashed #D4A86C;
}

/* ---- 场景信息 ---- */
.scene-info {
  flex: 1;
  min-width: 0;
}

.scene-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.scene-desc {
  font-size: 22rpx;
  color: #999;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 8rpx;
}

.scene-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.scene-goods-count {
  font-size: 20rpx;
  color: #FF8096;
}

.scene-sort {
  font-size: 20rpx;
  color: #BBB;
}

.scene-status {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.status-on {
  background: rgba(7, 193, 96, 0.1);
  color: #07c160;
}

.status-off {
  background: rgba(153, 153, 153, 0.1);
  color: #999;
}

/* ---- 操作按钮 ---- */
.scene-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F7F8FA;
}

.action-btn:active {
  background: #EEEEEE;
}

/* 启用/禁用图标 */
.toggle-icon {
  width: 20rpx;
  height: 12rpx;
  border-radius: 6rpx;
  position: relative;
}

.toggle-on {
  background: #07c160;
}

.toggle-on::after {
  content: '';
  position: absolute;
  right: 2rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #FFFFFF;
}

.toggle-off {
  background: #CCC;
}

.toggle-off::after {
  content: '';
  position: absolute;
  left: 2rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #FFFFFF;
}

/* 删除图标 */
.delete-icon {
  width: 16rpx;
  height: 16rpx;
  position: relative;
}

.delete-icon::before,
.delete-icon::after {
  content: '';
  position: absolute;
  width: 100%;
  height: 3rpx;
  background: #E8494A;
  top: 50%;
  left: 0;
  border-radius: 2rpx;
}

.delete-icon::before {
  transform: rotate(45deg);
}

.delete-icon::after {
  transform: rotate(-45deg);
}

/* ---- 空状态 ---- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F0EBE6, #F7F3EF);
  margin-bottom: 32rpx;
  position: relative;
}

.empty-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 36rpx;
  height: 36rpx;
  border: 3rpx dashed #D4A86C;
  border-radius: 8rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #BBB;
  margin-bottom: 60rpx;
}

.empty-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #FF8096;
  color: #FFFFFF;
  border-radius: 44rpx;
  padding: 24rpx 80rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(255, 128, 150, 0.3);
}

.empty-add-icon {
  width: 24rpx;
  height: 24rpx;
  position: relative;
}

.empty-add-icon::before,
.empty-add-icon::after {
  content: '';
  position: absolute;
  background: #FFFFFF;
  border-radius: 2rpx;
}

.empty-add-icon::before {
  width: 100%;
  height: 3rpx;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
}

.empty-add-icon::after {
  width: 3rpx;
  height: 100%;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
}

/* ---- 加载状态 ---- */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #D4A86C;
  animation: dot-bounce 1.4s ease-in-out infinite both;
}

.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.16s; }
.dot:nth-child(3) { animation-delay: 0.32s; }

@keyframes dot-bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* ---- 底部操作栏 ---- */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  z-index: 10;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #FF8096;
  color: #FFFFFF;
  border-radius: 44rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(255, 128, 150, 0.3);
}

.add-btn:active {
  opacity: 0.85;
}

.add-btn-icon {
  width: 20rpx;
  height: 20rpx;
  position: relative;
}

.add-btn-icon::before,
.add-btn-icon::after {
  content: '';
  position: absolute;
  background: #FFFFFF;
  border-radius: 2rpx;
}

.add-btn-icon::before {
  width: 100%;
  height: 4rpx;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
}

.add-btn-icon::after {
  width: 4rpx;
  height: 100%;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
}
