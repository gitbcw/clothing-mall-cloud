.container {
  position: relative;
  height: 100vh;
  background: #F7F8FA;
  display: flex;
  flex-direction: column;
}

/* ---- 品牌色 ---- */
/* primary: #FF8096 */

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.08);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  padding: 0 24rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.nav-placeholder-right {
  width: 60rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #F7F8FA;
  border-radius: 36rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #999;
  border-radius: 50%;
  margin-right: 12rpx;
  position: relative;
}

.search-icon::after {
  content: '';
  position: absolute;
  width: 10rpx;
  height: 3rpx;
  background: #999;
  bottom: -6rpx;
  right: -6rpx;
  transform: rotate(45deg);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-x {
  position: relative;
  width: 20rpx;
  height: 20rpx;
}

.clear-x::before,
.clear-x::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 3rpx;
  background: #999;
  border-radius: 2rpx;
}

.clear-x::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.clear-x::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

/* 商品列表 */
.goods-scroll {
  flex: 1;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 16rpx 24rpx;
}

/* 两列卡片布局 */
.goods-card {
  width: calc((100% - 20rpx) / 2);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.goods-card:active {
  transform: scale(0.97);
}

.card-selected {
  box-shadow: 0 0 0 3rpx #FF8096, 0 4rpx 16rpx rgba(255, 128, 150, 0.25);
}

.card-unselected {
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-img-area {
  position: relative;
  width: 100%;
  padding-top: 100%;
  overflow: hidden;
}

.card-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 勾选指示器 */
.indicator {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
  transition: all 0.2s ease;
}

.indicator-on {
  background: #FF8096;
  box-shadow: 0 2rpx 8rpx rgba(255, 128, 150, 0.4);
}

.indicator-off {
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  background: rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(4px);
}

.indicator-check {
  width: 18rpx;
  height: 12rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(-45deg);
  margin-top: -4rpx;
}

/* 选中遮罩 */
.card-tint {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 128, 150, 0.08);
  z-index: 2;
  pointer-events: none;
}

.card-body {
  padding: 16rpx;
  position: relative;
  z-index: 1;
  background: #fff;
}

.card-name {
  display: block;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.card-price {
  display: block;
  font-size: 28rpx;
  color: #FF8096;
  font-weight: 600;
  margin-top: 6rpx;
}

/* 加载状态 */
.scroll-footer {
  text-align: center;
  padding: 32rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部确认栏 */
.confirm-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.confirm-btn {
  height: 88rpx;
  background: #FF8096;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255, 128, 150, 0.3);
  transition: opacity 0.2s ease;
}

.confirm-btn-disabled {
  background: #ccc;
  box-shadow: none;
}
