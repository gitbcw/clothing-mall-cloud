@import "../../../styles/manager-common.wxss";

.container {
  min-height: 100vh;
  background-color: #F7F8FA;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ---- 导航栏 ---- */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.nav-placeholder-right {
  width: 60rpx;
}

.nav-placeholder {
  background: transparent;
}

/* ---- 表单区域 ---- */
.form-section {
  padding: 20rpx 24rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* ---- 穿搭图片 ---- */
.outfit-card {
  padding: 0;
  overflow: hidden;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 0;
  padding: 32rpx 32rpx 20rpx;
}

.outfit-upload {
  width: 100%;
  height: 900rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #D4A86C;
  background: linear-gradient(135deg, #FDF9F4, #F7F3EF);
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.upload-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(212, 168, 108, 0.15);
  position: relative;
}

.upload-icon::before,
.upload-icon::after {
  content: '';
  position: absolute;
  background: #D4A86C;
  border-radius: 2rpx;
}

.upload-icon::before {
  width: 50%;
  height: 3rpx;
  top: 50%;
  left: 25%;
  transform: translateY(-50%);
}

.upload-icon::after {
  width: 3rpx;
  height: 50%;
  left: 50%;
  top: 25%;
  transform: translateX(-50%);
}

.upload-text {
  font-size: 24rpx;
  color: #D4A86C;
}

.uploading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #F0EBE6;
  border-top-color: #D4A86C;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.outfit-preview {
  width: 100%;
  height: 900rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.outfit-image {
  width: 100%;
  height: 100%;
}

/* 悬浮商品栏 */
.outfit-float-panel {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 220rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
}

.float-pos--left {
  left: 32rpx;
}

.float-pos--right {
  right: 32rpx;
}

.outfit-float-title {
  background: #ff8096;
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  padding: 12rpx 0;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.outfit-goods-scroll {
  max-height: 580rpx;
  width: 100%;
}

.outfit-good-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 16rpx 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.outfit-good-item:last-child {
  border-bottom: none;
}

.outfit-good-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  margin-bottom: 12rpx;
}

.outfit-good-price {
  font-size: 24rpx;
  color: #ff8096;
  font-weight: 500;
}

/* ---- 品牌水印（线框） ---- */
.brand-watermark {
  position: absolute;
  top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 28rpx;
  border-radius: 12rpx;
  pointer-events: none;
}

.brand-pos--top-left {
  left: 32rpx;
}

.brand-pos--top-right {
  right: 32rpx;
}

.brand-main {
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.15;
  letter-spacing: 6rpx;
}

.brand-sub {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.15;
  letter-spacing: 4rpx;
  margin-top: 4rpx;
}

/* 白色 */
.brand-watermark--white {
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.brand-watermark--white .brand-main,
.brand-watermark--white .brand-sub {
  color: rgba(255, 255, 255, 0.88);
}

/* 咖啡色 */
.brand-watermark--coffee {
  border: 2rpx solid rgba(107, 66, 38, 0.4);
}

.brand-watermark--coffee .brand-main,
.brand-watermark--coffee .brand-sub {
  color: rgba(107, 66, 38, 0.88);
}

/* ---- 颜色选择器 ---- */
.color-picker {
  display: flex;
  gap: 32rpx;
}

.color-option {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.color-active {
  border-color: #D4A86C;
  background: rgba(212, 168, 108, 0.06);
}

.color-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #e0e0e0;
}

.color-circle--white {
  background: #FFFFFF;
  border-color: #d0d0d0;
}

.color-circle--coffee {
  background: #6B4226;
  border-color: #6B4226;
}

.color-label {
  font-size: 24rpx;
  color: #666;
}

/* 位置选择图标 */
.pos-icon {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ccc;
  border-radius: 4rpx;
  position: relative;
}

.pos-icon--left::after {
  content: '';
  position: absolute;
  left: 6rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 2rpx;
  background: #999;
}

.pos-icon--right::after {
  content: '';
  position: absolute;
  right: 6rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 2rpx;
  background: #999;
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 20rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.cover-btn {
  font-size: 22rpx;
  color: #FFFFFF;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(8px);
}

.cover-btn:active {
  background: rgba(255, 255, 255, 0.4);
}

.cover-btn-delete {
  background: rgba(232, 73, 74, 0.6);
}

.cover-btn-delete:active {
  background: rgba(232, 73, 74, 0.8);
}

/* ---- 字段组 ---- */
.field-group {
  padding: 8rpx 0;
}

.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.field-required {
  color: #E8494A;
  margin-right: 4rpx;
}

.field-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.field-hint-inline {
  font-size: 22rpx;
  color: #999;
  font-weight: 400;
  margin-left: 8rpx;
}

.field-input {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 0;
  width: 100%;
}

.field-input--small {
  width: 160rpx;
  text-align: right;
  padding: 0;
}

/* ---- 步进器 ---- */
.stepper {
  display: flex;
  align-items: center;
  gap: 0;
}

.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #96745A;
  background: rgba(150, 116, 90, 0.08);
  border-radius: 12rpx;
  user-select: none;
}

.stepper-btn:active {
  background: rgba(150, 116, 90, 0.18);
}

.stepper-btn-disabled {
  color: #ccc;
  background: #f5f5f5;
}

.stepper-btn-disabled:active {
  background: #f5f5f5;
}

.stepper-input {
  width: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  padding: 0 8rpx;
}

.field-textarea {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 0;
  width: 100%;
  min-height: 80rpx;
  line-height: 1.6;
}

.field-divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 8rpx 0;
}

.field-info {
  display: flex;
  flex-direction: column;
}

/* ---- 关联商品 ---- */
.add-goods-btn {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(150, 116, 90, 0.08);
}

.add-goods-text {
  font-size: 24rpx;
  color: #96745A;
  font-weight: 500;
}

.goods-list {
  margin-top: 16rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-item-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.goods-item-info {
  flex: 1;
  margin-left: 16rpx;
  min-width: 0;
}

.goods-item-name {
  display: block;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-item-price {
  display: block;
  font-size: 24rpx;
  color: #E8494A;
  margin-top: 4rpx;
}

.goods-item-remove {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.remove-icon {
  font-size: 28rpx;
  color: #999;
}

/* ---- 开关 ---- */
.toggle-switch {
  width: 88rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #E0E0E0;
  position: relative;
  transition: background 0.3s ease;
  flex-shrink: 0;
}

.toggle-active {
  background: #07c160;
}

.toggle-knob {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #FFFFFF;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: transform 0.3s ease;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
}

.toggle-active .toggle-knob {
  transform: translateX(40rpx);
}

/* ---- 保存按钮 ---- */
.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  z-index: 10;
}

.save-btn {
  background: #FF8096;
  color: #FFFFFF;
  border-radius: 44rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(255, 128, 150, 0.3);
}

.save-btn:active {
  opacity: 0.85;
}

.save-btn-disabled {
  opacity: 0.5;
}
