@import "../../../styles/manager-common.wxss";

.container {
  min-height: 100vh;
  background-color: #F7F8FA;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fff;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

/* 子 Tab */
.sub-tabs {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  position: sticky;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.sub-tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.sub-tab-item.active {
  color: #FF8096;
  font-weight: 600;
}

.sub-tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #FF8096;
  border-radius: 3rpx;
}

/* 上架表单区域 */
.upload-section {
  padding-bottom: 160rpx;
}

/* 草稿提示 */
.draft-tip {
  position: fixed;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  right: 24rpx;
  background: rgba(255, 128, 150, 0.9);
  color: #fff;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  z-index: 50;
}

.draft-tip-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.draft-icon {
  font-size: 28rpx;
}

.draft-time {
  font-size: 22rpx;
  opacity: 0.8;
}

.draft-tip-actions {
  display: flex;
  gap: 12rpx;
}

.draft-tip-btn {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
}

.draft-tip-btn-danger {
  background: rgba(255, 255, 255, 0.15);
}

/* ========== 商品列表 ========== */
.list-section {
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

.list-tabs {
  display: flex;
  background: #fff;
  padding: 0 40rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.list-tab-item {
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.list-tab-item.active {
  color: #FF8096;
  font-weight: 600;
}

.list-tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #FF8096;
  border-radius: 2rpx;
}

.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
}

.search-input {
  background: #F5F5F5;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #FDFCFB;
}

.list-header-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.header-btn {
  font-size: 24rpx;
  color: #FF8096;
  padding: 8rpx 20rpx;
  border: 1rpx solid #FF8096;
  border-radius: 24rpx;
}

.list-count {
  font-size: 24rpx;
  color: #999;
}

.unpublish-all-btn {
  font-size: 24rpx;
  color: #E8494A;
  padding: 8rpx 20rpx;
  border: 1rpx solid #E8494A;
  border-radius: 24rpx;
}

/* 批量操作栏 */
.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 128, 150, 0.08);
  border-bottom: 1rpx solid rgba(255, 128, 150, 0.2);
}

.batch-count {
  font-size: 26rpx;
  color: #FF8096;
  font-weight: 500;
}

.batch-actions {
  display: flex;
  gap: 16rpx;
}

.batch-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.batch-btn.select-all {
  color: #FF8096;
  border: 1rpx solid #FF8096;
}

.batch-btn.delete {
  color: #fff;
  background: #E8494A;
}

.goods-list {
  padding: 0 24rpx;
}

.goods-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  align-items: center;
}

.goods-card.batch-mode {
  padding-left: 12rpx;
}

.goods-checkbox {
  flex: 0 0 auto;
  padding: 16rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  border-color: #FF8096;
  background: #FF8096;
}

.checkbox-mark {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #F5F5F5;
}

.goods-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.goods-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.status-tag.status-published {
  color: #67C23A;
  background: rgba(103, 194, 58, 0.1);
}

.status-tag.status-pending {
  color: #E6A23C;
  background: rgba(230, 162, 60, 0.1);
}

.goods-price {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 8rpx;
}

.retail-price {
  font-size: 32rpx;
  color: #E8494A;
  font-weight: 600;
}

.counter-price {
  font-size: 24rpx;
  color: #ccc;
  text-decoration: line-through;
}

.special-price {
  font-size: 24rpx;
  color: #FF8096;
  background: rgba(255, 128, 150, 0.1);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.goods-actions {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
  margin-left: 12rpx;
  align-self: center;
}

.goods-btn {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
  color: #666;
  text-align: center;
  white-space: nowrap;
}

.goods-btn.btn-primary {
  background: rgba(255, 128, 150, 0.1);
  color: #FF8096;
}

.goods-btn.btn-warning {
  background: rgba(232, 73, 74, 0.08);
  color: #E8494A;
}

.goods-btn.btn-danger {
  background: rgba(232, 73, 74, 0.08);
  color: #E8494A;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  color: #999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}
