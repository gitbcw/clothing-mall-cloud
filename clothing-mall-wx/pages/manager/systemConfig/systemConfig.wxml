<wxs src="../../../utils/image.wxs" module="img" />
<view class="container">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight + 16}}px; height: {{navBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-back" bindtap="onBack">
        <view class="nav-back-icon"></view>
      </view>
      <view class="nav-title">系统配置</view>
      <view class="nav-placeholder-right"></view>
    </view>
  </view>
  <view class="nav-placeholder" style="height: {{statusBarHeight + navBarHeight + 16}}px;"></view>

  <!-- 表单 -->
  <view class="form-section">
    <!-- 活动位背景图 -->
    <view class="form-card">
      <view class="form-label">活动位背景图</view>
      <view class="field-hint" style="margin-bottom: 20rpx;">首页活动区域的背景图片，建议使用宽图</view>

      <!-- 上传区域 -->
      <view class="poster-upload" wx:if="{{!form.activityBgImage}}" bindtap="onChooseBgImage">
        <view class="upload-placeholder" wx:if="{{!uploading}}">
          <view class="upload-icon"></view>
          <text class="upload-text">上传背景图</text>
        </view>
        <view class="uploading-state" wx:if="{{uploading}}">
          <view class="loading-spinner"></view>
          <text class="upload-text">上传中...</text>
        </view>
      </view>

      <!-- 预览 -->
      <view class="poster-preview" wx:if="{{form.activityBgImage}}">
        <image class="poster-image" src="{{img.url(form.activityBgImage)}}" mode="aspectFill" />
        <view class="poster-overlay">
          <view class="poster-btn" bindtap="onChooseBgImage">更换</view>
          <view class="poster-btn poster-btn-delete" bindtap="onRemoveBgImage">删除</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-bar">
    <view class="save-btn {{saving ? 'save-btn-disabled' : ''}}" bindtap="{{saving ? '' : 'onSave'}}">
      <text>{{saving ? '保存中...' : '保存'}}</text>
    </view>
  </view>
</view>
