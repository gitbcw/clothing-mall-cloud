@import "../../../styles/manager-common.wxss";

.container {
  min-height: 100vh;
  background-color: #F7F8FA;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ---- 导航栏 ---- */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.nav-placeholder-right {
  width: 60rpx;
}

.nav-placeholder {
  background: transparent;
}

/* ---- 表单区域 ---- */
.form-section {
  padding: 20rpx 24rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* ---- 图片上传 ---- */
.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.field-hint {
  font-size: 22rpx;
  color: #999;
}

.poster-upload {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #487EB0;
  background: linear-gradient(135deg, #F4F8FC, #EFF5FA);
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.upload-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(72, 126, 176, 0.15);
  position: relative;
}

.upload-icon::before,
.upload-icon::after {
  content: '';
  position: absolute;
  background: #487EB0;
  border-radius: 2rpx;
}

.upload-icon::before {
  width: 50%;
  height: 3rpx;
  top: 50%;
  left: 25%;
  transform: translateY(-50%);
}

.upload-icon::after {
  width: 3rpx;
  height: 50%;
  left: 50%;
  top: 25%;
  transform: translateX(-50%);
}

.upload-text {
  font-size: 24rpx;
  color: #487EB0;
}

.uploading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E8F0F7;
  border-top-color: #487EB0;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.poster-preview {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.poster-image {
  width: 100%;
  height: 100%;
}

.poster-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 20rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.poster-btn {
  font-size: 22rpx;
  color: #FFFFFF;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(8px);
}

.poster-btn:active {
  background: rgba(255, 255, 255, 0.4);
}

.poster-btn-delete {
  background: rgba(232, 73, 74, 0.6);
}

.poster-btn-delete:active {
  background: rgba(232, 73, 74, 0.8);
}

/* ---- 保存按钮 ---- */
.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  z-index: 10;
}

.save-btn {
  background: #FF8096;
  color: #FFFFFF;
  border-radius: 44rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(255, 128, 150, 0.3);
}

.save-btn:active {
  opacity: 0.85;
}

.save-btn-disabled {
  opacity: 0.5;
}
