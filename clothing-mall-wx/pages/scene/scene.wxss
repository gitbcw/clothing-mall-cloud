/* ================================================================
   Scene Page - Refined Editorial Style
   ================================================================ */

page {
  background: #F7F8FA;
}

.container {
  min-height: 100vh;
  background: #F7F8FA;
}

/* ── Navigation ── */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.88);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  backdrop-filter: saturate(180%) blur(20px);
}

.nav-bar {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s;
}

.nav-back:active {
  background: rgba(0, 0, 0, 0.05);
}

.back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 2rpx;
  margin-right: 64rpx;
}

/* ── Scene Header ── */
.scene-header {
  position: relative;
  padding: 36rpx 36rpx 32rpx;
  margin: 16rpx 24rpx 0;
  background: linear-gradient(135deg, #fff 0%, #FEF8F9 100%);
  border-radius: 20rpx;
  overflow: hidden;
}

.scene-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #FF8096, #FFB3C1, #FF8096);
}

.scene-header::after {
  content: '';
  position: absolute;
  right: -30rpx;
  bottom: -30rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 128, 150, 0.08), transparent 70%);
}

.scene-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.7;
  position: relative;
  z-index: 1;
}

/* ── Goods Waterfall ── */
.goods-content {
  display: flex;
  padding: 20rpx 20rpx 0;
  box-sizing: border-box;
}

.waterfall-col {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.waterfall-col:first-child {
  margin-right: 12rpx;
}

.waterfall-col:last-child {
  margin-left: 12rpx;
}

/* ── Goods Card ── */
.goods-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.goods-card:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.goods-img {
  width: 100%;
  display: block;
  background: #f5f5f5;
  height: 120rpx;
}

.goods-info {
  padding: 20rpx 20rpx 24rpx;
}

.goods-name {
  font-size: 26rpx;
  color: #1a1a1a;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.5;
  letter-spacing: 0.5rpx;
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.goods-price-symbol {
  font-size: 24rpx;
  color: #FF8096;
  font-weight: 500;
}

.goods-price {
  font-size: 32rpx;
  color: #FF8096;
  font-weight: 600;
  margin-left: 2rpx;
  letter-spacing: 1rpx;
}

/* ── Load More ── */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 20rpx;
  gap: 12rpx;
}

.load-more text {
  font-size: 26rpx;
  color: #bbb;
  letter-spacing: 2rpx;
}

.loading-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.loading-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #ccc;
  animation: dotPulse 1.4s infinite ease-in-out both;
}

.loading-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes dotPulse {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* ── Empty State ── */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF5F7, #FFE8EC);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  position: relative;
}

.empty-hanger {
  width: 48rpx;
  height: 60rpx;
  position: relative;
}

.empty-hanger::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #FFD4DC;
  border-radius: 50%;
}

.empty-hanger::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 32rpx;
  border: 4rpx solid #FFD4DC;
  border-radius: 0 0 8rpx 8rpx;
  border-top: none;
}

.empty-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}

/* ── No More ── */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 60rpx 0;
  gap: 20rpx;
}

.no-more-line {
  flex: 1;
  height: 1rpx;
  background: #e8e8e8;
}

.no-more text {
  font-size: 24rpx;
  color: #ccc;
  white-space: nowrap;
}
