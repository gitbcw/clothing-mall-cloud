/* ==============================
   页面容器
   ============================== */
.container {
  min-height: 100vh;
  background: #F7F8FA;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* ==============================
   头像区域
   ============================== */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0rpx 0 100rpx;
}

.avatar-btn {
  position: relative;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  display: none;
}

.avatar-wrap {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 128, 150, 0.2);
}

.avatar {
  width: 100%;
  height: 100%;
}

/* 相机编辑角标 */
.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 40rpx;
  height: 40rpx;
  background: #FF8096;
  border-radius: 50%;
  border: 3rpx solid #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-body {
  width: 16rpx;
  height: 12rpx;
  border: 2rpx solid #FFFFFF;
  border-radius: 2rpx;
  position: relative;
}

.camera-body::before {
  content: '';
  position: absolute;
  top: -5rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 4rpx;
  background: #FFFFFF;
  border-radius: 2rpx 2rpx 0 0;
}

.avatar-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 16rpx;
}

/* ==============================
   表单卡片
   ============================== */
.form-card {
  margin: 0 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 0 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

/* 行 */
.form-row {
  display: flex;
  align-items: center;
  height: 108rpx;
}

.row-label {
  width: 140rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  flex-shrink: 0;
}

.row-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
  padding-right: 16rpx;
  height: 108rpx;
}

.row-placeholder {
  color: #999;
  font-size: 28rpx;
}

.row-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
  padding-right: 16rpx;
}

.row-value.muted {
  color: #999;
}

/* 箭头 */
.row-arrow {
  flex-shrink: 0;
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #999999;
  border-right: 2rpx solid #999999;
  transform: rotate(45deg);
  /* 占位用，保证右侧对齐 — 隐藏箭头可加 transparent-arrow class */
}

.row-arrow.transparent {
  border-color: transparent;
}

/* 分割线 */
/* 手机号绑定按钮 - 伪装成普通行 */
.phone-bind-btn {
  display: block;
  width: 100%;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
  text-align: left;
}

.phone-bind-btn::after {
  display: none;
}

.row-divider {
  height: 1rpx;
  background: #F5F5F5;
}

/* ==============================
   生日提示
   ============================== */
.birthday-tip {
  margin: 20rpx 24rpx 0;
  padding: 16rpx 24rpx;
  background: rgba(255, 128, 150, 0.06);
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #FF8096;
  text-align: center;
}

/* ==============================
   保存按钮
   ============================== */
.save-area {
  padding: 80rpx 48rpx 60rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: #FF8096;
  color: #FFFFFF;
  font-size: 30rpx;
  letter-spacing: 2rpx;
  border: none;
  padding: 0;
  margin: 0;
}

.save-btn::after {
  display: none;
}

.save-btn-active {
  opacity: 0.85;
}