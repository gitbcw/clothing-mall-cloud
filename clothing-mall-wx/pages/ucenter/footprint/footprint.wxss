page {
  background: #f4f4f4;
  min-height: 100%;
}

.container {
  background: #f4f4f4;
  min-height: 100%;
}

/* ================================================================
   Empty State
   ================================================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 240rpx;
}

.empty-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF5F7, #FFE8EC);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
}

/* Eye icon - CSS only */
.empty-eye {
  width: 56rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.eye-outer {
  width: 56rpx;
  height: 32rpx;
  border: 4rpx solid #FFD4DC;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.eye-pupil {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #FFD4DC;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* ================================================================
   List Hint
   ================================================================ */
.footprint-list {
  padding: 0 24rpx;
}

.list-hint {
  padding: 20rpx 0 8rpx;
}

.list-hint-text {
  font-size: 22rpx;
  color: #ccc;
}

/* ================================================================
   Date Header (Timeline Style)
   ================================================================ */
.day-group {
  margin-bottom: 12rpx;
}

.date-header {
  display: flex;
  align-items: center;
  padding: 28rpx 0 16rpx;
}

.date-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #FF8096;
  flex-shrink: 0;
}

.date-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.date-line {
  flex: 1;
  height: 1rpx;
  background: #e8e8e8;
  margin-left: 16rpx;
}

/* ================================================================
   Goods Card
   ================================================================ */
.goods-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.goods-card:active {
  opacity: 0.85;
}

.goods-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f4f4f4;
}

.goods-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.goods-top {
  display: flex;
  flex-direction: column;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-brief {
  font-size: 24rpx;
  color: #999;
  line-height: 34rpx;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-bottom {
  display: flex;
  align-items: center;
}

.goods-price {
  font-size: 32rpx;
  color: #FF8096;
  font-weight: 600;
}

/* ================================================================
   Footer
   ================================================================ */
.list-footer {
  padding: 32rpx 0 64rpx;
  text-align: center;
}

.no-more-text {
  font-size: 24rpx;
  color: #ccc;
}
