page {
  min-height: 100%;
  width: 100%;
  background: #F7F8FA;
}

.container {
  min-height: 100%;
  width: 100%;
}

.address-list {
  padding: 0 20rpx;
  background-size: auto 10.5rpx;
  margin-bottom: 90rpx;
}

.address-list .item {
  background-color: white;
  border-radius:16rpx;
  padding: 0 30rpx;
  margin-top: 20rpx;
  height: 140rpx;
  align-items: center;
  display: flex;
}

