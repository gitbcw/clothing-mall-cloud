.address-list .l {
  width: 100rpx;
  height: 80rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.address-list .name {
  width: 125rpx;
  height: 43rpx;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 5.2rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
  overflow: hidden;
  text-align: center;
  font-weight: bold;
}

.address-list .default {
  width: 62.5rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 18rpx;
  color: white;
  background-color: #FF8096;
  border-radius: 20rpx;
  visibility: visible;
}

.address-list .c {
  flex: 1;
  height: auto;
  overflow: hidden;
}

.address-list .mobile {
  height: 29rpx;
  font-size: 30rpx;
  line-height: 29rpx;
  overflow: hidden;
  color: #333;
  margin-bottom: 6.25rpx;
}

.address-list .address {
  height: 37rpx;
  font-size: 28rpx;
  line-height: 37rpx;
  overflow: hidden;
  color: #666;
}

.address-list .r {
  width: 52rpx;
  height: auto;
  overflow: hidden;
  margin-right: 16.5rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.address-list .del {
  display: block;
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
}

.add-address {
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 90%;
  height: 90rpx;
  line-height: 90rpx;
  position: absolute;
  bottom: 60rpx;
  left: 5%;
  border-radius: 45rpx;
  padding: 0;
  margin: 0;
  text-align: center;
  font-size: 28rpx;
  color: #ffffff;
  letter-spacing: 3rpx;
  background: #FF8096;
}

.empty-view {
  min-height: 60vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-view .text {
  width: auto;
  font-size: 28rpx;
  line-height: 35rpx;
  color: #999;
}
