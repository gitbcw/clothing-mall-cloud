page {
  height: 100%;
  background: #F7F8FA;
}

.add-address .add-form {
  background: #FFFFFF;
  height: auto;
  overflow: hidden;
  margin: 20rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
}

.add-address .add-form .form-item {
  background: #ffffff;
  border-radius: 0rpx;
  margin: 15rpx 24rpx;
  height: 100rpx;
  padding-left: 31.25rpx;
  display: flex;
  align-items: center;
  padding-right: 25rpx;
  border-bottom:  #eee 1px solid;
}

.add-address .input {
  flex: 1;
  height: 44rpx;
  line-height: 44rpx;
  overflow: hidden;
  padding-left: 10rpx;
  font-size: 32rpx;
  color: #333;
}

.add-address .form-default {
  height: 96rpx;
  background: #eeeeee;
  font-size: 32rpx;
  padding-left: 25rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: UICTFontTextStyleBody;
  border-bottom: none !important;
}

.add-address .form-default .van-checkbox .van-icon {
  color: #fff;
}

.add-address .btns {
  position: fixed;
  bottom: 60rpx;
  left: 0;
  overflow: hidden;
  display: flex;
  height: 100rpx;
  width: 100%;
  padding: 0 30rpx;
  box-sizing: border-box;
  box-shadow: none;
}

.add-address .cannel, .add-address .save {
  flex: 1;
  height: 96rpx;
  text-align: center;
  line-height: 96rpx;
  font-size: 32rpx;
  color: #fff;
  border: none;
  border-radius: 48rpx;
  margin: 0 10rpx;
}

