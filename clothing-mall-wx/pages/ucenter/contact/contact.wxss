.container {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 0 32rpx;
  box-sizing: border-box;
}

/* 客服卡片 */
.contact-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-top: 32rpx;
}

.card-header {
  padding: 48rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, rgba(248, 227, 187, 0.25) 0%, rgba(248, 227, 187, 0.08) 100%);
}

.header-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(139, 115, 85, 0.08);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #999;
}

/* 二维码区域 */
.qr-section {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-img {
  width: 400rpx;
  height: 400rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.qr-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 24rpx;
  text-align: center;
  line-height: 1.6;
}

/* 未配置状态 */
.qr-empty {
  padding: 60rpx 40rpx;
}

.empty-icon {
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #ccc;
}

/* 文案说明 */
.desc-section {
  padding: 0 40rpx 40rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 工作时间 */
.work-hours {
  margin-top: 32rpx;
  text-align: center;
  padding: 32rpx;
}

.hours-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.hours-text {
  font-size: 28rpx;
  color: #666;
}
