page {
  height: 100%;
  width: 100%;
  background: #f4f4f4;
}

/* 快递信息头 */
.express-header-card {
  background: linear-gradient(135deg, #FF8096 0%, #FFB3C1 100%);
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.express-header-row {
  display: flex;
  align-items: center;
}

.express-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.express-icon {
  font-size: 40rpx;
}

.express-header-info {
  display: flex;
  flex-direction: column;
}

.express-company {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.express-no {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 1rpx;
}

/* 时间轴区域 */
.timeline-section {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

/* 空状态 */
.timeline-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.timeline-empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.timeline-empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.timeline-empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

/* 时间轴列表 */
.timeline-list {
  padding-left: 4rpx;
}

.timeline-item {
  display: flex;
  min-height: 120rpx;
}

.timeline-item:last-child {
  min-height: auto;
}

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 32rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.timeline-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #FFD4DC;
  border: 3rpx solid #FFB3C1;
  flex-shrink: 0;
  margin-top: 8rpx;
  box-sizing: border-box;
}

.timeline-dot-active {
  background: #FF8096;
  border-color: #FF8096;
  box-shadow: 0 0 12rpx rgba(255, 128, 150, 0.4);
}

.timeline-line {
  flex: 1;
  width: 2rpx;
  background: #FFD4DC;
  margin: 4rpx 0;
}

.timeline-right {
  flex: 1;
  padding-bottom: 32rpx;
}

.timeline-item:last-child .timeline-right {
  padding-bottom: 0;
}

.timeline-station {
  font-size: 28rpx;
  color: #999;
  line-height: 42rpx;
  display: block;
}

.timeline-station-active {
  color: #333;
  font-weight: 500;
}

.timeline-time {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 6rpx;
  display: block;
}
