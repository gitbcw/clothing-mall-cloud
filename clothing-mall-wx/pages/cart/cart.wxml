<wxs src="../../utils/image.wxs" module="img" />
<view class="container">
  <!-- 沉浸式自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight+16}}px; height: {{navBarHeight}}px;">
    <view class="back-btn" bindtap="goBack">
      <view class="back-icon"></view>
    </view>
    <view class="nav-title">购物车</view>
    <view class="nav-right"></view>
  </view>

  <!-- 占位，防止内容被吸顶导航栏遮挡 -->
  <view class="nav-placeholder" style="height: {{statusBarHeight + navBarHeight}}px;"></view>

  <!-- 未登录状态 -->
  <view class="empty-cart" wx:if="{{!hasLogin}}">
    <image class="empty-illustration" src="{{emptyImage}}" mode="aspectFit" binderror="onEmptyImageError"></image>
    <text class="empty-title">登录后同步你的购物清单</text>
    <text class="empty-text">已选商品、优惠信息和订单状态将自动保存</text>
    <view class="action-row">
      <view class="ghost-btn" bindtap="goBack">先去逛逛</view>
      <view class="login-btn" bindtap="goLogin">立即登录</view>
    </view>
  </view>

  <!-- 空购物车 -->
  <view class="empty-cart" wx:elif="{{cartGoods.length === 0}}">
    <view class="empty-cart-icon"></view>
    <text class="empty-title">购物车空空如也</text>
    <text class="empty-text">把喜欢的商品加入购物车，结算更方便</text>
    <view class="login-btn" bindtap="goBack">去逛逛</view>
  </view>

  <!-- 购物车内容 -->
  <block wx:else>
    <!-- 头部工具栏 -->
    <view class="header-toolbar">
      <view class="toolbar-left">
        <view class="bag-icon"></view>
        <text class="total-count">共{{cartTotal.goodsCount}}件商品</text>
      </view>
      <view class="toolbar-right" bindtap="toggleManageMode">{{isManageMode ? '完成' : '管理'}}</view>
    </view>

    <!-- 内容区域 -->
    <scroll-view class="content-wrap" scroll-y="true">
      <!-- 商品列表 -->
      <view class="cart-list">
        <view class="cart-item card" wx:for="{{cartGoods}}" wx:key="id">
          <!-- 单选框 -->
          <view class="radio-wrap" bindtap="checkedItem" data-item-index="{{index}}">
            <view class="radio {{item.checked ? 'checked' : ''}}"></view>
          </view>

          <!-- 商品信息 -->
          <view class="goods-info" bindtap="goToDetail" data-goods-id="{{item.goodsId}}">
            <view class="img-wrap">
              <image class="goods-img" src="{{img.url(item.picUrl) || defaultGoodsImage}}" mode="aspectFill" binderror="onCartImageError" data-item-index="{{index}}"></image>
            </view>
            <view class="goods-detail">
              <view class="goods-title">{{item.goodsName}}</view>
              <view class="goods-desc" wx:if="{{item.specifications}}">{{item.specifications}}</view>
              <view class="goods-desc" wx:elif="{{item.size}}">{{item.size}}</view>
              <view class="goods-bottom">
                <view class="price-wrap">
                  <text class="price-symbol">￥</text>
                  <text class="price-num">{{item.price}}</text>
                </view>
                <!-- 步进器 -->
                <view class="stepper">
                  <view class="step-btn minus" bindtap="cutNumber" data-item-index="{{index}}"></view>
                  <view class="step-input">{{item.number}}</view>
                  <view class="step-btn plus" bindtap="addNumber" data-item-index="{{index}}"></view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 底部占位，防止被结算栏和TabBar遮挡 -->
      <view class="bottom-placeholder"></view>
    </scroll-view>

    <!-- 底部结算栏 -->
    <view class="checkout-bar">
      <view class="checkout-left" bindtap="checkedAll">
        <view class="radio {{checkedAllStatus ? 'checked' : ''}}"></view>
        <text class="select-all-text">全选</text>
      </view>
      <view class="checkout-right" wx:if="{{!isManageMode}}">
        <view class="total-info">
          <view class="total-price-wrap">
            <text class="total-label">总计：</text>
            <text class="total-symbol theme-color">￥</text>
            <text class="total-price theme-color">{{cartTotal.checkedGoodsAmount}}</text>
          </view>
        </view>
        <view class="btn-checkout" bindtap="checkoutOrder">去结算({{cartTotal.checkedGoodsCount}})</view>
      </view>
      <view class="checkout-right" wx:else>
        <view class="btn-checkout delete-btn" bindtap="deleteCart">删除</view>
      </view>
    </view>
  </block>
</view>
