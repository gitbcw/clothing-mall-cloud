.goods-form {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.goods-form-scroll {
  flex: 1;
  height: 0; /* 关键：配合 flex:1 使 scroll-view 填满剩余空间 */
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.section {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 吊牌识别按钮 */
.tag-recognize-btn {
  font-size: 24rpx;
  font-weight: normal;
  color: #FF8096;
  background: rgba(255, 128, 150, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 128, 150, 0.3);
}

/* 图片上传 */
.image-upload {
  margin-bottom: 24rpx;
}

.main-image {
  width: 300rpx;
  height: 300rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.image-recognizing-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}

.recognizing-text {
  color: #fff;
  font-size: 24rpx;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #ccc;
}

.upload-icon {
  font-size: 64rpx;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.gallery-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.gallery-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}

.gallery-image {
  width: 100%;
  height: 100%;
}

.gallery-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 0 0 8rpx;
}

.gallery-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ccc;
}

/* 表单 */
.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item.third,
.form-item.half {
  flex: 1;
  min-width: 0;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.form-label .required {
  color: #E8494A;
}

.input-wrapper {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.form-input {
  background: transparent;
  padding: 0;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  height: 100%;
  display: flex;
  align-items: center;
}

.form-textarea {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.picker-value.placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 32rpx;
  color: #999;
}

/* 场景标签 */
.scene-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.scene-chip {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid transparent;
}

.scene-chip.active {
  background: #FF8096;
  color: #fff;
  border-color: #FF8096;
}

/* 富文本编辑器 */
.editor-wrap {
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  overflow: hidden;
}

.editor-toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-bottom: 1rpx solid #e8e8e8;
}

.toolbar-btn {
  height: 64rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #333;
  background: #fff;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
}

.toolbar-btn.italic {
  font-style: italic;
}

.toolbar-btn.active {
  background: #FF8096;
  color: #fff;
  border-color: #FF8096;
}

.editor-content {
  width: 100%;
  min-height: 400rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 商品参数 */
.add-param-btn {
  font-size: 24rpx;
  color: #FF8096;
  font-weight: normal;
}

.params-list {
  margin-top: 16rpx;
}

.param-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.param-row:last-child {
  margin-bottom: 0;
}

.param-input {
  background: #F5F5F5;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.param-key {
  flex: 1;
}

.param-value {
  flex: 2;
}

.param-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d4f;
  font-size: 32rpx;
  background: rgba(255, 77, 79, 0.08);
  border-radius: 50%;
}

.params-empty {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 底部操作栏 - 基础样式 */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

/* 有 tab bar 时（tabShelf）- 留出 tab bar 空间 */
.action-bar--with-tabbar {
  bottom: calc(100rpx + env(safe-area-inset-bottom));
}

/* 无 tab bar 时（goodsEdit）- 贴底 */
.action-bar--bottom {
  bottom: 0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.action-btn.btn-save {
  color: #FF8096;
  background: rgba(255, 128, 150, 0.08);
}

.action-btn.btn-publish {
  color: #fff;
  background: #FF8096;
}

.action-btn.btn-unpublish {
  color: #ff9800;
  background: rgba(255, 152, 0, 0.1);
}

.action-btn.btn-preview {
  color: #FF8096;
  background: rgba(255, 128, 150, 0.08);
}

/* 分类选择器 */
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.picker-confirm {
  font-size: 28rpx;
  color: #FF8096;
  width: 60rpx;
}
