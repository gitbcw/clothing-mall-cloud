.goods-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.goods-image-wrap {
  position: relative;
  width: 100%;
  padding-top: 100%; /* 1:1 比例 */
  overflow: hidden;
}

.goods-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.goods-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  color: #fff;
  background: #FF8096;
  border-radius: 4rpx;
}

.goods-tag.hot {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.goods-tag.special {
  background: linear-gradient(135deg, #E74C3C 0%, #ff6b6b 100%);
}

.goods-info {
  padding: 16rpx;
}

.goods-name {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  min-height: 72rpx;
}

.goods-brief {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.goods-price {
  color: #f44;
  font-weight: 600;
}

.price-symbol {
  font-size: 22rpx;
}

.price-value {
  font-size: 32rpx;
}

.goods-origin-price {
  margin-left: 12rpx;
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
}

.goods-sales {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 列表模式 */
.goods-card-list {
  display: flex;
  padding: 20rpx;
}

.goods-card-list .goods-image-wrap {
  width: 200rpx;
  padding-top: 200rpx;
  flex-shrink: 0;
}

.goods-card-list .goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 0 0 0 20rpx;
}

.goods-card-list .goods-name {
  min-height: auto;
  -webkit-line-clamp: 2;
}

/* 快速加购按钮 */
.quick-cart {
  position: absolute;
  right: 16rpx;
  bottom: 130rpx;
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #f44, #ff6b6b);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(244, 68, 68, 0.3);
  z-index: 10;
}

.quick-cart:active {
  transform: scale(0.95);
  opacity: 0.9;
}
