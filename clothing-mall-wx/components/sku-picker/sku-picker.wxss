/* SKU 选择器组件样式 */
.sku-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.sku-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.sku-container {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  max-height: 80vh;
  overflow-y: auto;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.sku-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.close-icon {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.sku-header {
  display: flex;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.sku-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.sku-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.sku-price {
  font-size: 40rpx;
  color: #ff8096;
  font-weight: bold;
}

.sku-stock {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.sku-selected {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.sku-section {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.sku-section-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.sku-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.sku-option {
  padding: 16rpx 28rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #333;
  background: #f9f9f9;
  transition: all 0.2s;
}

.sku-option.selected {
  border-color: #ff8096;
  color: #ff8096;
  background: #fff0f3;
}

.sku-option.disabled {
  color: #ccc;
  background: #f5f5f5;
  border-color: #eee;
}

.color-option {
  display: flex;
  align-items: center;
}

.color-image {
  width: 40rpx;
  height: 40rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.size-option {
  min-width: 80rpx;
  text-align: center;
}

.sku-quantity {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #e5e5e5;
  border-radius: 50%;
  font-size: 36rpx;
  color: #333;
  background: #f9f9f9;
}

.quantity-btn.disabled {
  color: #ccc;
}

.quantity-input {
  width: 100rpx;
  height: 64rpx;
  text-align: center;
  font-size: 28rpx;
  margin: 0 16rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 32rpx;
}

.sku-footer {
  display: flex;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.sku-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-cart {
  background: #A0785A;
  color: #fff;
  border-radius: 44rpx 0 0 44rpx;
}

.btn-buy {
  background: #ff8096;
  color: #fff;
  border-radius: 0 44rpx 44rpx 0;
}
