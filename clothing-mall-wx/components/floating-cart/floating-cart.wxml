<view class="floating-toolbar">
  <view class="floating-btn-group">
    <!-- 购物车（最上） -->
    <view class="floating-btn cart-btn" bindtap="goToCart">
      <view class="cart-icon"></view>
      <view class="cart-badge" wx:if="{{count > 0}}">{{count > 99 ? '99+' : count}}</view>
    </view>

    <!-- 分享 -->
    <button class="floating-btn share-btn" open-type="share">
      <view class="share-icon"></view>
    </button>

    <!-- 客服（展开时显示，在分享下方） -->
    <view class="floating-btn cs-btn {{expanded ? 'btn-visible' : 'btn-hidden'}}" bindtap="openCs">
      <view class="chat-icon"></view>
    </view>

    <!-- 展开/收起（最底） -->
    <view class="floating-btn toggle-btn {{expanded ? 'toggle-expanded' : ''}}" bindtap="toggleExpand">
      <van-icon name="plus" size="24px" color="{{  expanded ? '#FFFFFF':'#ff8096' }}" />
    </view>
  </view>
</view>
