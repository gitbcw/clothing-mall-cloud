/* 悬浮工具栏 */
.floating-toolbar {
  position: relative;
  z-index: 999;
}

.floating-btn-group {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.floating-btn {
  width: 100rpx;
  height: 100rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 8rpx rgba(255, 128, 150, 0.1);
  position: relative;
}

.floating-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

/* 购物车角标 */
.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: #ff8096;
  box-sizing: border-box;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  border-radius: 18rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

/* 分享按钮重置 */
.share-btn {
  background: #fff !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  line-height: normal !important;
  box-shadow: 0 4rpx 8rpx rgba(255, 128, 150, 0.1);
}

.share-btn::after {
  border: none;
}

/* 展开按钮 */
.toggle-btn {
  transition: all 0.3s ease;
}

.toggle-btn.toggle-expanded {
  transform: rotate(45deg);
  background: #cccccc;
  color: white;
  box-shadow: none;
}

/* 客服按钮：向上展开动画 */
.cs-btn {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.cs-btn.btn-hidden {
  opacity: 0;
  transform: translateY(20rpx) scale(0.5);
  max-height: 0;
  overflow: hidden;
  pointer-events: none;
  margin-bottom: -24rpx;
}

.cs-btn.btn-visible {
  opacity: 1;
  transform: translateY(0) scale(1);
  max-height: 120rpx;
  pointer-events: auto;
}

