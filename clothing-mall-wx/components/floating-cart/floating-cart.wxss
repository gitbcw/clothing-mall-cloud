.floating-cart {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background: rgba(248, 227, 187, 0.4);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(139, 115, 85, 0.25);
  z-index: 999;
}

.floating-cart:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: #8B7355;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  border-radius: 18rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}
