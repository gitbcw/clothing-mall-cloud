.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-sn {
  font-size: 24rpx;
  color: #666;
}

.order-status {
  font-size: 26rpx;
  font-weight: 500;
}

.goods-list {
  padding: 20rpx 24rpx;
}

.goods-item {
  display: flex;
  padding: 16rpx 0;
}

.goods-item:not(:last-child) {
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.goods-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.goods-price {
  font-size: 28rpx;
  color: #333;
}

.goods-number {
  font-size: 24rpx;
  color: #999;
}

.order-footer {
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
}

.order-total {
  font-size: 24rpx;
  color: #666;
  text-align: right;
}

.total-text {
  margin-left: 16rpx;
}

.total-price {
  font-size: 32rpx;
  color: #f44;
  font-weight: 600;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
}

.action-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  border: 1rpx solid #ddd;
  border-radius: 32rpx;
}

.action-btn.primary {
  color: #fff;
  background: #f44;
  border-color: #f44;
}
