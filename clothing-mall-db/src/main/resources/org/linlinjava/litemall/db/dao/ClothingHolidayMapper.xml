<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.linlinjava.litemall.db.dao.ClothingHolidayMapper">

    <resultMap id="BaseResultMap" type="org.linlinjava.litemall.db.domain.ClothingHoliday">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="start_date" property="startDate"/>
        <result column="end_date" property="endDate"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="enabled" property="enabled"/>
        <result column="add_time" property="addTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, start_date, end_date, sort_order, enabled, add_time, update_time, deleted
    </sql>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM clothing_holiday
        WHERE id = #{id} AND deleted = 0
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM clothing_holiday
        WHERE deleted = 0
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="selectByEnabled" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM clothing_holiday
        WHERE enabled = #{enabled} AND deleted = 0
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="selectActive" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM clothing_holiday
        WHERE deleted = 0 AND enabled = 1
          AND start_date &lt;= #{date} AND end_date &gt;= #{date}
        ORDER BY sort_order ASC, id ASC
    </select>

    <insert id="insertSelective" parameterType="org.linlinjava.litemall.db.domain.ClothingHoliday" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO clothing_holiday
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="startDate != null">start_date,</if>
            <if test="endDate != null">end_date,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="enabled != null">enabled,</if>
            deleted, add_time, update_time,
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="startDate != null">#{startDate},</if>
            <if test="endDate != null">#{endDate},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="enabled != null">#{enabled},</if>
            0, NOW(), NOW(),
        </trim>
    </insert>

    <update id="updateByPrimaryKeySelective" parameterType="org.linlinjava.litemall.db.domain.ClothingHoliday">
        UPDATE clothing_holiday
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="enabled != null">enabled = #{enabled},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <update id="deleteByPrimaryKey">
        UPDATE clothing_holiday SET deleted = 1 WHERE id = #{id}
    </update>

</mapper>
