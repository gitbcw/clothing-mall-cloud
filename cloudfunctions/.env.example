# CloudBase 云函数环境变量配置
# 创建云函数时，将这些变量设置到 func.envVariables 中
# 每个云函数都需要配置这些变量

# ==================== MySQL 连接（必需）====================
MYSQL_HOST=172.17.0.12
MYSQL_PORT=3306
MYSQL_USER=clo
MYSQL_PASSWORD=Clo@123456
MYSQL_DATABASE=clo-test-4g8ukdond34672de

# ==================== VPC 配置（必需）====================
# 云函数必须绑定 VPC 才能访问内网 MySQL
# 通过 SCF API 配置：UpdateFunctionConfiguration
VPC_ID=vpc-ebub59uy
VPC_SUBNET_ID=subnet-pedhih1v
VPC_NAMESPACE=clo-test-4g8ukdond34672de

# ==================== AI 识别（可选，不配走 Mock）====================
# 火山引擎 Doubao Vision API
DOUBAO_ENDPOINT=
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-2-0-mini
AI_ENABLED=true

# ==================== 物流查询（可选）====================
# 阿里云市场物流查询 APPCODE
EXPRESS_APPCODE=

# ==================== 云开发环境 ====================
# CloudBase 环境 ID（云函数内部可用）
TCB_ENV_ID=clo-test-4g8ukdond34672de

# ==================== 微信支付（可选）====================
# 模拟支付开关：true=模拟（开发测试），false=真实微信支付（需商户号）
MOCK_PAY=true
