<view class="container">
  <!-- 沉浸式自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
    <view class="back-btn" bindtap="goBack">
      <view class="back-icon"></view>
    </view>
    <view class="nav-title">确认订单</view>
    <view class="nav-right"></view>
  </view>

  <!-- 占位，防止内容被吸顶导航栏遮挡 -->
  <view class="nav-placeholder" style="height: {{statusBarHeight + navBarHeight}}px;"></view>

  <view class="content-wrap">
    <!-- 地址选择卡片 -->
    <view class="card address-card">
      <view class="address-left">
        <view class="location-icon"></view>
        <view class="address-info">
          <view class="address-detail">广东广州天河区黄埔大道</view>
          <view class="address-user">七尾 1320253202</view>
        </view>
      </view>
      <view class="arrow"></view>
    </view>

    <!-- 订单信息卡片 -->
    <view class="card order-card">
      <!-- 商品信息 -->
      <view class="goods-info">
        <view class="img-wrap">
          <image class="goods-img" src="{{goods.image}}" mode="aspectFill"></image>
        </view>
        <view class="goods-detail">
          <view class="goods-title">{{goods.title}}</view>
          <view class="goods-desc">{{goods.desc}}</view>
          <view class="goods-bottom">
            <view class="price-wrap">
              <text class="price-symbol">￥</text>
              <text class="price-num">{{goods.price}}</text>
            </view>
            <view class="goods-count">×{{goods.count}}</view>
          </view>
        </view>
      </view>

      <!-- 费用明细 -->
      <view class="fee-list">
        <view class="fee-item">
          <text class="fee-label">运费</text>
          <text class="fee-value theme-color">￥{{fee.freight}}</text>
        </view>
        <view class="fee-item">
          <text class="fee-label">商品小计</text>
          <text class="fee-value theme-color">￥{{fee.subtotal}}</text>
        </view>
        <view class="fee-item" bindtap="openCouponModal">
          <text class="fee-label">优惠券</text>
          <view class="coupon-value">
            <text class="coupon-text selected">{{fee.couponDesc}}</text>
            <view class="arrow small-arrow selected"></view>
          </view>
        </view>
      </view>

      <!-- 合计 -->
      <view class="total-wrap">
        <text class="total-label">合计：</text>
        <text class="total-symbol theme-color">￥</text>
        <text class="total-num theme-color">{{fee.total}}</text>
      </view>
    </view>

    <!-- 支付方式卡片 -->
    <view class="card payment-card">
      <text class="payment-label">支付方式</text>
      <view class="payment-right">
        <text class="payment-value">{{paymentMethod}}</text>
        <view class="arrow"></view>
      </view>
    </view>
  </view>

  <!-- 底部固定栏 -->
  <view class="bottom-bar">
    <view class="bottom-left">
      <text class="bottom-symbol theme-color">￥</text>
      <text class="bottom-price theme-color">{{fee.subtotal}}</text>
    </view>
    <view class="btn-submit">立即购买</view>
  </view>
  <!-- 底部安全区占位 -->
  <view class="safe-area-placeholder"></view>

  <!-- 优惠券弹窗 (Half-Screen Modal) -->
  <view class="modal-mask" wx:if="{{showCouponModal}}" bindtap="closeCouponModal"></view>
  <view class="modal-container {{showCouponModal ? 'show' : ''}}">
    <view class="modal-header">
      <view class="modal-title">优惠券</view>
      <view class="close-btn" bindtap="closeCouponModal">
        <view class="close-icon"></view>
      </view>
    </view>
    
    <view class="modal-content">
      <view class="modal-tip">
        <text>优惠券可叠加使用，一共3张优惠券，可抵扣 </text>
        <text class="theme-color">￥60.0</text>
      </view>
      
      <scroll-view class="coupon-list" scroll-y="true">
        <view class="coupon-item" wx:for="{{coupons}}" wx:key="id" bindtap="toggleCoupon" data-id="{{item.id}}">
          <view class="coupon-left">
            <view class="coupon-amount-wrap">
              <text class="coupon-symbol">￥</text>
              <text class="coupon-amount">{{item.amount}}</text>
            </view>
            <view class="coupon-condition">{{item.condition}}</view>
          </view>
          <view class="coupon-right">
            <view class="coupon-info">
              <view class="coupon-title">{{item.title}}</view>
              <view class="coupon-time">{{item.validTime}}</view>
              <view class="coupon-desc">{{item.desc}}</view>
            </view>
            <view class="coupon-radio {{item.selected ? 'checked' : ''}}"></view>
          </view>
          <!-- 锯齿边缘装饰 -->
          <view class="sawtooth"></view>
        </view>
        <!-- 底部空白占位 -->
        <view class="list-bottom-placeholder"></view>
      </scroll-view>
    </view>

    <view class="modal-bottom">
      <view class="btn-confirm" bindtap="closeCouponModal">确定</view>
    </view>
    <view class="safe-area-placeholder-modal"></view>
  </view>
</view>