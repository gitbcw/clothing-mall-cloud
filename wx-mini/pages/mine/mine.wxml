<view class="container">
  <!-- 顶部背景与个人信息 -->
  <view class="header-section">
    <image class="bg-img" src="https://images.unsplash.com/photo-1567401893414-76b7b1e5a7a5?ixlib=rb-1.2.1&auto=format&fit=crop&w=1000&q=80" mode="aspectFill"></image>
    <view class="user-info">
      <view class="avatar-wrap">
        <image class="avatar" src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?ixlib=rb-1.2.1&auto=format&fit=crop&w=200&q=80" mode="aspectFill"></image>
      </view>
      <view class="info-text">
        <view class="nickname">薛定谔的猫</view>
        <view class="status">未登录</view>
      </view>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content-section">
    
    <!-- 我的订单 -->
    <view class="card order-card">
      <view class="card-header" bindtap="handleNav" data-url="全部订单">
        <text class="title">我的订单</text>
        <view class="more">全部 <text class="arrow">></text></view>
      </view>
      <view class="order-list">
        <view class="order-item" bindtap="handleNav" data-url="待支付">
          <view class="icon icon-wallet"></view>
          <text>待支付</text>
        </view>
        <view class="order-item" bindtap="handleNav" data-url="待发货">
          <view class="icon icon-truck"></view>
          <text>待发货</text>
        </view>
        <view class="order-item" bindtap="handleNav" data-url="待收货">
          <view class="icon icon-package"></view>
          <text>待收货</text>
        </view>
        <view class="order-item" bindtap="handleNav" data-url="已完成">
          <view class="icon icon-receipt"></view>
          <text>已完成</text>
        </view>
      </view>
    </view>

    <!-- 功能列表 1 -->
    <view class="card menu-card">
      <view class="menu-item" bindtap="handleNav" data-url="收货地址管理">
        <view class="item-left">
          <view class="icon icon-location"></view>
          <text>收货地址管理</text>
        </view>
        <view class="item-right">
          <text class="arrow">></text>
        </view>
      </view>
      <view class="menu-item" bindtap="handleNav" data-url="优惠券">
        <view class="item-left">
          <view class="icon icon-ticket"></view>
          <text>优惠券</text>
        </view>
        <view class="item-right">
          <text class="arrow">></text>
        </view>
      </view>
      <view class="menu-item" bindtap="handleNav" data-url="我的收藏">
        <view class="item-left">
          <view class="icon icon-star"></view>
          <text>我的收藏</text>
        </view>
        <view class="item-right">
          <text class="arrow">></text>
        </view>
      </view>
      <view class="menu-item" bindtap="handleNav" data-url="浏览足迹">
        <view class="item-left">
          <view class="icon icon-footprint"></view>
          <text>浏览足迹</text>
        </view>
        <view class="item-right">
          <text class="arrow">></text>
        </view>
      </view>
    </view>

    <!-- 功能列表 2 -->
    <view class="card menu-card">
      <view class="menu-item" bindtap="handleNav" data-url="联系客服">
        <view class="item-left">
          <view class="icon icon-headset"></view>
          <text>联系客服</text>
        </view>
        <view class="item-right">
          <text class="arrow">></text>
        </view>
      </view>
      <view class="menu-item" bindtap="handleNav" data-url="个人信息">
        <view class="item-left">
          <view class="icon icon-person"></view>
          <text>个人信息</text>
        </view>
        <view class="item-right">
          <text class="arrow">></text>
        </view>
      </view>
    </view>

    <!-- 底部安全区占位，防止内容被底部导航栏遮挡 -->
    <view class="safe-area-placeholder"></view>
  </view>
</view>