/* Container */
.container {
  width: 100%;
  min-height: 100vh;
  position: relative;
  box-sizing: border-box;
}

/* Header Section */
.header-section {
  position: relative;
  width: 100%;
  height: 480rpx; /* Matches the visual proportion */
}

.bg-img {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

/* User Info Box */
.user-info {
  position: absolute;
  top: 240rpx;
  left: 48rpx;
  z-index: 2;
  display: flex;
  align-items: center;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  background-color: #fff;
}

.avatar {
  width: 100%;
  height: 100%;
}

.info-text {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.nickname {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.status {
  font-size: 24rpx;
  color: #666;
}

/* Content Section */
.content-section {
  position: relative;
  z-index: 3;
  width: 100%;
  padding: 0 32rpx;
  margin-top: -60rpx; /* Overlaps background */
  box-sizing: border-box;
}

/* Card General */
.card {
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  width: 100%;
  box-sizing: border-box;
}

/* Order Card */
.order-card {
  padding: 32rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.card-header .title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.card-header .more {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
}

.arrow {
  font-family: Arial;
  font-size: 24rpx;
  color: #ccc;
  margin-left: 8rpx;
}

.order-list {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}

.order-item text {
  font-size: 24rpx;
  color: #333;
  margin-top: 16rpx;
}

/* Menu Card */
.menu-card {
  padding: 0 32rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
}

.item-left text {
  font-size: 28rpx;
  color: #333;
  margin-left: 20rpx;
}

.item-right .arrow {
  font-size: 28rpx;
}

/* Safe Area Placeholder */
.safe-area-placeholder {
  height: 140rpx;
  width: 100%;
  padding-bottom: env(safe-area-inset-bottom);
}

/* Custom Tab Bar */
.custom-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-top: 1rpx solid #EAEAEA;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 25%;
  height: 100%;
}

.tab-item text {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.tab-item.active text {
  color: #FF8096; /* Based on the brownish active icon color */
}

/* ----- ICONS ----- */
.icon {
  width: 48rpx;
  height: 48rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

