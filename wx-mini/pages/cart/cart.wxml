<view class="container">
  <!-- 沉浸式自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
    <view class="back-btn" bindtap="goBack">
      <view class="back-icon"></view>
    </view>
    <view class="nav-title">购物车</view>
    <view class="nav-right">
      <view class="nav-icons">
        <view class="icon-more"></view>
        <view class="icon-target"></view>
      </view>
    </view>
  </view>

  <!-- 占位，防止内容被吸顶导航栏遮挡 -->
  <view class="nav-placeholder" style="height: {{statusBarHeight + navBarHeight}}px;"></view>

  <!-- 头部工具栏 -->
  <view class="header-toolbar">
    <view class="toolbar-left">
      <view class="bag-icon"></view>
      <text class="total-count">共{{cartList.length}}件商品</text>
    </view>
    <view class="toolbar-right" bindtap="toggleManageMode">{{isManageMode ? '完成' : '管理'}}</view>
  </view>

  <!-- 内容区域 -->
  <scroll-view class="content-wrap" scroll-y="true">
    
    <!-- 正常商品列表 -->
    <view class="cart-list">
      <view class="cart-item card" wx:for="{{cartList}}" wx:key="id">
        <!-- 单选框 -->
        <view class="radio-wrap" bindtap="toggleSelect" data-id="{{item.id}}">
          <view class="radio {{item.selected ? 'checked' : ''}}"></view>
        </view>
        
        <!-- 商品信息 -->
        <view class="goods-info">
          <view class="img-wrap">
            <image class="goods-img" src="{{item.image}}" mode="aspectFill"></image>
          </view>
          <view class="goods-detail">
            <view class="goods-title">{{item.title}}</view>
            <view class="goods-desc">{{item.desc}}</view>
            <view class="goods-bottom">
              <view class="price-wrap">
                <text class="price-symbol">￥</text>
                <text class="price-num">{{item.price}}</text>
                <text class="original-price">￥{{item.originalPrice}}</text>
              </view>
              <!-- 步进器 -->
              <view class="stepper">
                <view class="step-btn minus" bindtap="minusCount" data-id="{{item.id}}"></view>
                <view class="step-input">{{item.count}}</view>
                <view class="step-btn plus" bindtap="addCount" data-id="{{item.id}}"></view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 失效商品模块 -->
    <view class="invalid-module card">
      <view class="invalid-header">
        <text class="invalid-title">2件商品失效</text>
        <text class="invalid-clear">清空失效商品</text>
      </view>
      
      <view class="invalid-list">
        <view class="invalid-item" wx:for="{{invalidList}}" wx:key="id">
          <!-- 失效标签占位 -->
          <view class="invalid-tag-wrap">
            <view class="invalid-tag">失效</view>
          </view>
          
          <view class="goods-info invalid-goods">
            <view class="img-wrap invalid-img-wrap">
              <image class="goods-img" src="{{item.image}}" mode="aspectFill"></image>
              <!-- 半透明遮罩 -->
              <view class="img-mask"></view>
            </view>
            <view class="goods-detail">
              <view class="goods-title">{{item.title}}</view>
              <view class="goods-desc">{{item.desc}}</view>
              <view class="goods-bottom">
                <view class="price-wrap">
                  <text class="price-symbol">￥</text>
                  <text class="price-num">{{item.price}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 底部占位，防止被结算栏和TabBar遮挡 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>

  <!-- 底部结算栏 -->
  <view class="checkout-bar">
    <view class="checkout-left" bindtap="toggleAllSelect">
      <view class="radio {{isAllSelected ? 'checked' : ''}}"></view>
      <text class="select-all-text">全选</text>
    </view>
    <view class="checkout-right" wx:if="{{!isManageMode}}">
      <view class="total-info">
        <view class="total-price-wrap">
          <text class="total-label">总计：</text>
          <text class="total-symbol theme-color">￥</text>
          <text class="total-price theme-color">{{totalPrice}}</text>
        </view>
        <view class="discount-info">已优惠￥{{discountPrice}}</view>
      </view>
      <view class="btn-checkout" bindtap="goToCheckout">去结算({{selectedCount}})</view>
    </view>
    <view class="checkout-right" wx:else>
      <view class="btn-checkout" style="background: #ff4d4f; color: #fff;" bindtap="deleteSelected">删除</view>
    </view>
  </view>
</view>