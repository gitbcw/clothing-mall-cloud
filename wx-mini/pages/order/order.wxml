<view class="container">
  <!-- 自定义导航栏与 Tabs (吸顶) -->
  <view class="header-wrap" style="padding-top: {{statusBarHeight}}px;">
    <!-- 导航栏 -->
    <view class="nav-bar" style="height: {{navBarHeight}}px;">
      <view class="back-btn" bindtap="goBack">
        <view class="back-icon"></view>
      </view>
      <view class="nav-title">全部订单</view>
      <view class="nav-right"></view>
    </view>
    
    <!-- Tabs 分类 -->
    <view class="tabs">
      <block wx:for="{{tabs}}" wx:key="*this">
        <view class="tab-item {{currentTab === index ? 'active' : ''}}" bindtap="switchTab" data-index="{{index}}">
          <text>{{item}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 顶部占位，防止内容被 fixed 头部遮挡 -->
  <!-- 44 是 tabs 的大概高度 (px) -->
  <view class="header-placeholder" style="height: {{statusBarHeight + navBarHeight + 44}}px;"></view>

  <!-- 订单列表区 -->
  <view class="order-list">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card">
        <!-- 商品信息区 -->
        <view class="goods-info">
          <image class="goods-img" src="{{item.image}}" mode="aspectFill"></image>
          
          <view class="goods-detail">
            <!-- 标题与状态 -->
            <view class="detail-top">
              <view class="goods-title">{{item.title}}</view>
              <view class="goods-status">{{item.status}}</view>
            </view>
            
            <!-- 描述 -->
            <view class="goods-desc">{{item.desc}}</view>
            
            <!-- 价格与数量 -->
            <view class="detail-bottom">
              <view class="price-wrap">
                <text class="price-symbol">￥</text>
                <text class="price-num">{{item.price}}</text>
                <text class="original-price" wx:if="{{item.originalPrice}}">￥{{item.originalPrice}}</text>
              </view>
              <view class="goods-count">×{{item.count}}</view>
            </view>
          </view>
        </view>
        
        <!-- 操作按钮区 -->
        <view class="action-box">
          <block wx:for="{{item.buttons}}" wx:for-item="btn" wx:key="text">
            <view class="btn {{btn.type === 'primary' ? 'btn-primary' : 'btn-default'}}">{{btn.text}}</view>
          </block>
        </view>
      </view>
    </block>
  </view>
</view>