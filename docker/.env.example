# ===========================================
# Clothing Mall Docker 环境变量配置
# 复制此文件为 .env 并修改相应配置
# ===========================================

# -------------------------------------------
# 基础配置
# -------------------------------------------
# 运行环境: local | production
ENV=local

# 时区
TZ=Asia/Shanghai

# -------------------------------------------
# MySQL 配置
# -------------------------------------------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=clothing_mall
MYSQL_USER=clothing_mall
MYSQL_PASSWORD=clothing123456

# MySQL 资源限制
MYSQL_MEMORY_LIMIT=512M

# -------------------------------------------
# Java 应用配置
# -------------------------------------------
# JVM 参数
JAVA_OPTS=-Xmx512m -Xms256m

# 应用端口（容器内部）
APP_INTERNAL_PORT=8080
# 应用端口（宿主机）
APP_EXTERNAL_PORT=8088

# -------------------------------------------
# Nginx 配置
# -------------------------------------------
# Nginx HTTP 端口
NGINX_HTTP_PORT=80
# Nginx HTTPS 端口
NGINX_HTTPS_PORT=443

# -------------------------------------------
# 代理配置（国内网络环境）
# -------------------------------------------
# HTTP 代理（用于拉取镜像、下载依赖）
HTTP_PROXY_HOST=host.docker.internal
HTTP_PROXY_PORT=7897
# 是否启用代理
USE_PROXY=false

# -------------------------------------------
# 微信小程序配置
# -------------------------------------------
WX_APP_ID=wxa5b486c6b918ecfb
WX_APP_SECRET=e04004829d4c383b4db7769d88dfbca1
WX_MCH_ID=111111
WX_MCH_KEY=xxxxxx
WX_NOTIFY_URL=http://localhost:8088/wx/order/pay-notify

# -------------------------------------------
# 存储配置
# -------------------------------------------
# 存储模式: local | aliyun | tencent
STORAGE_ACTIVE=local
# 本地存储访问地址
STORAGE_LOCAL_ADDRESS=http://localhost:8088/wx/storage/fetch/

# 阿里云 OSS 配置（如使用）
ALIYUN_OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET_NAME=

# -------------------------------------------
# 通知配置
# -------------------------------------------
# 邮件通知
MAIL_ENABLE=false
MAIL_HOST=smtp.exmail.qq.com
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SENDFROM=
MAIL_SENDTO=
MAIL_PORT=465

# 短信通知
SMS_ENABLE=false
SMS_ACTIVE=tencent
SMS_SIGN=litemall

# -------------------------------------------
# 快递物流查询配置（阿里云市场API）
# -------------------------------------------
EXPRESS_ENABLE=false
EXPRESS_APPCODE=
